{
	"name": "file-drive",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@trpc/server": "^11.16.0",
			"better-auth": "1.5.5",
			"next-themes": "^0.4.6",
			"@trpc/tanstack-react-query": "^11.16.0",
			"@trpc/client": "^11.16.0",
			"@tanstack/react-query": "^5.90.12",
			"@tanstack/react-form": "^1.28.0",
			"@types/react-dom": "^19.2.3",
			"@better-auth/expo": "1.5.5",
			"drizzle-orm": "^0.45.1",
			"drizzle-zod": "^0.8.3",
			"@types/pg": "^8.16.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @file-drive/db db:push",
		"db:studio": "turbo -F @file-drive/db db:studio",
		"db:generate": "turbo -F @file-drive/db db:generate",
		"db:migrate": "turbo -F @file-drive/db db:migrate",
		"db:start": "turbo -F @file-drive/db db:start",
		"db:watch": "turbo -F @file-drive/db db:watch",
		"db:stop": "turbo -F @file-drive/db db:stop",
		"db:down": "turbo -F @file-drive/db db:down",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@file-drive/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@file-drive/config": "workspace:*",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "^6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "bun@1.3.13"
}
