{
	"name": "file-drive",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/bun": "latest",
		"dotenv": "^17.3.1",
		"turbo": "^2.9.4"
	},
	"scripts": {
		"dev": "turbo dev",
		"lint": "turbo lint",
